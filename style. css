
/* Reset Global */
* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

/* Configuração do Corpo e Estampa Meiga de Papel de Parede */
body {
    font-family: 'Segoe UI', Arial, sans-serif;
    color: #6c4664;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    
    /* Papel de parede estampado bem meigo em degrade lilás/rosa com mini corações e brilhos em CSS */
    background-color: #f3e5f5;
    background-image: 
        radial-gradient(rgba(255, 105, 180, 0.15) 15%, transparent 16%),
        radial-gradient(rgba(255, 182, 193, 0.2) 15%, transparent 16%),
        linear-gradient(45deg, rgba(255, 192, 203, 0.1) 25%, transparent 25%, transparent 75%, rgba(255, 192, 203, 0.1) 75%, rgba(255, 192, 203, 0.1)),
        linear-gradient(45deg, rgba(255, 192, 203, 0.1) 25%, #f3e5f5 25%, #f3e5f5 75%, rgba(255, 192, 203, 0.1) 75%, rgba(255, 192, 203, 0.1));
    background-size: 40px 40px, 40px 40px, 40px 40px, 40px 40px;
    background-position: 0 0, 20px 20px, 0 0, 20px 20px;
}

/* Barra de Navegação */
.navbar {
    width: 100%;
    background: rgba(255, 255, 255, 0.9);
    padding: 15px 30px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 2px solid #f0cfe3;
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(5px);
}

.nav-logo {
    font-size: 1.4rem;
    font-weight: bold;
    color: #b3367a;
}

.nav-links a {
    text-decoration: none;
    color: #7b5272;
    margin-left: 20px;
    font-size: 0.95rem;
    font-weight: 500;
    transition: color 0.2s;
}

.nav-links a:hover, .cart-nav {
    color: #ff4081;
}

.cart-nav span {
    background: #ff4081;
    color: white;
    padding: 2px 8px;
    border-radius: 10px;
    font-size: 0.8rem;
}

/* Banner do Cabeçalho */
.main-header {
    width: 92%;
    max-width: 1000px;
    background: linear-gradient(135deg, #fff0f6, #ffdeeb);
    border-radius: 25px;
    padding: 40px 20px;
    text-align: center;
    margin-top: 25px;
    border: 3px solid #ffb3d1;
    box-shadow: 0 10px 25px rgba(243, 142, 193, 0.3);
    position: relative;
    overflow: hidden;
}

.main-header h1 {
    font-size: 2.8rem;
    color: #d81b60;
    letter-spacing: 2px;
    text-shadow: 2px 2px #ffb3d1;
    margin-bottom: 10px;
}

.tagline {
    font-size: 1.1rem;
    color: #884d72;
    font-style: italic;
    margin-bottom: 20px;
}

.badges {
    display: flex;
    justify-content: center;
    gap: 15px;
    flex-wrap: wrap;
    margin-bottom: 15px;
}

.badges span {
    background: white;
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 0.85rem;
    border: 1px solid #ffccd5;
    color: #c2185b;
}

.stamp {
    display: inline-block;
    background: #ff4081;
    color: white;
    font-weight: bold;
    padding: 8px 18px;
    border-radius: 30px;
    transform: rotate(-3deg);
    font-size: 0.9rem;
    box-shadow: 0 4px 10px rgba(255, 64, 129, 0.3);
}

/* Categorias */
.categorias-container {
    display: flex;
    justify-content: center;
    gap: 10px;
    flex-wrap: wrap;
    margin: 25px 0;
    width: 90%;
    max-width: 800px;
}

.cat-btn {
    background: white;
    border: 2px solid #e1bee7;
    padding: 8px 16px;
    border-radius: 20px;
    cursor: pointer;
    color: #8e24aa;
    font-weight: 600;
    font-size: 0.85rem;
    transition: all 0.2s ease;
}

.cat-btn:hover, .cat-btn.ativo {
    background: #ba68c8;
    color: white;
    border-color: #ba68c8;
    transform: scale(1.05);
}

/* Título de Seções */
.section-title {
    font-size: 1.6rem;
    color: #ad1457;
    margin: 15px 0;
    text-shadow: 1px 1px white;
}

/* Grid da Vitrine */
.vitrine-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 20px;
    width: 92%;
    max-width: 1000px;
    padding: 10px 0 40px 0;
}

/* Card de Sticker Lindo */
.sticker-card {
    background: white;
    border-radius: 20px;
    padding: 15px;
    text-align: center;
    border: 2px solid #f8bbd0;
    box-shadow: 0 8px 16px rgba(216, 27, 96, 0.1);
    position: relative;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: center;
}

.sticker-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 22px rgba(216, 27, 96, 0.2);
    border-color: #f48fb1;
}

.heart-icon {
    position: absolute;
    top: 10px;
    right: 12px;
    color: #ff4081;
    cursor: pointer;
    font-size: 0.95rem;
}

.sticker-img {
    width: 100px;
    height: 100px;
    background: radial-gradient(#fff5f8, #ffebf2);
    border: 3px dashed #f48fb1; /* Borda tracejada simulando recorte real */
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 3.2rem;
    margin: 10px 0;
    transition: transform 0.3s ease;
}

.sticker-card:hover .sticker-img {
    transform: scale(1.1) rotate(6deg);
}

.sticker-card h3 {
    font-size: 0.95rem;
    color: #4a148c;
    margin-bottom: 5px;
}

.preco {
    font-size: 1.1rem;
    font-weight: bold;
    color: #e91e63;
    margin-bottom: 12px;
}

.btn-comprar {
    background: #ec407a;
    color: white;
    border: none;
    padding: 8px 20px;
    font-weight: bold;
    border-radius: 15px;
    cursor: pointer;
    width: 100%;
    font-size: 0.85rem;
    box-shadow: 0 3px 8px rgba(236, 64, 122, 0.3);
    transition: background 0.2s;
}

.btn-comprar:hover {
    background: #d81b60;
}

/* Modais de Pagamento PIX */
.modal-pix {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(74, 20, 140, 0.4);
    backdrop-filter: blur(4px);
    z-index: 1000;
    justify-content: center;
    align-items: center;
}

.modal-content {
    background: white;
    padding: 30px;
    border-radius: 25px;
    max-width: 400px;
    width: 90%;
    text-align: center;
    position: relative;
    border: 3px solid #f48fb1;
    box-shadow: 0 15px 35px rgba(0,0,0,0.2);
    animation: abrirModal 0.3s ease-out;
}

@keyframes abrirModal {
    from { transform: scale(0.8); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
}

.close-btn {
    position: absolute;
    top: 12px;
    right: 20px;
    font-size: 1.8rem;
    cursor: pointer;
    color: #884d72;
}

.modal-header h3 {
    color: #d81b60;
    margin: 10px 0 5px 0;
    font-size: 1.4rem;
}

.pix-box {
    background: #fff0f5;
    border-radius: 15px;
    padding: 20px;
    margin: 15px 0;
    border: 1px solid #ffccd5;
}

.total-text {
    font-size: 1.1rem;
    font-weight: bold;
    margin-bottom: 15px;
}

.total-text span {
    color: #e91e63;
    font-size: 1.4rem;
}

/* QR Code Estilizado Meigo */
.qrcode-placeholder {
    width: 140px;
    height: 140px;
    margin: 0 auto 15px auto;
    background: white;
    border: 4px solid #ba68c8;
    border-radius: 10px;
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
}

.qr-code-lines {
    width: 80%;
    height: 80%;
    background: linear-gradient(45deg, #333 25%, transparent 25%, transparent 75%, #333 75%, #333), 
                linear-gradient(45deg, #333 25%, white 25%, white 75%, #333 75%, #333);
    background-size: 20px 20px;
    opacity: 0.8;
}

.qr-logo {
    position: absolute;
    background: #00bfa5;
    color: white;
    font-weight: bold;
    font-size: 0.75rem;
    padding: 2px 6px;
    border-radius: 4px;
}

.pix-instruction {
    font-size: 0.8rem;
    color: #6a1b9a;
    margin-bottom: 10px;
}

.copia-cola-container {
    display: flex;
    gap: 5px;
}

.copia-cola-container input {
    flex: 1;
    padding: 8px;
    border-radius: 10px;
    border: 1px solid #ce93d8;
    font-size: 0.8rem;
    color: #555;
    outline: none;
}

.copia-cola-container button {
    background: #00bfa5;
    color: white;
    border: none;
    padding: 8px 12px;
    border-radius: 10px;
    cursor: pointer;
    font-weight: bold;
    font-size: 0.8rem;
}

.feedback-text {
    display: none;
    color: #2e7d32;
    font-size: 0.8rem;
    font-weight: bold;
    margin-top: 8px;
}

.aviso-entrega {
    font-size: 0.8rem;
    color: #ad1457;
    font-weight: 500;
}

/* Rodapé */
footer {
    margin-top: auto;
    width: 100%;
    background: rgba(255, 255, 255, 0.8);
    text-align: center;
    padding: 25px;
    border-top: 2px solid #f0cfe3;
}

footer p {
    font-size: 1rem;
    color: #b3367a;
    font-weight: 600;
}

.sub-footer {
    font-size: 0.8rem !important;
    color: #9c7893 !important;
    margin-top: 5px;
}
